/**
 * @file  wifi_credentials.h.example
 * @brief Template for WiFi credentials — copy to wifi_credentials.h and fill in.
 *
 * Usage:
 *   1. Copy this file:   cp wifi_credentials.h.example wifi_credentials.h
 *   2. Edit wifi_credentials.h with your actual SSID and password.
 *   3. wifi_credentials.h is .gitignored and will not be committed.
 */

#ifndef WIFI_CREDENTIALS_H
#define WIFI_CREDENTIALS_H

#define WIFI_SSID     "YOUR_WIFI_SSID_HERE"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD_HERE"

#endif // WIFI_CREDENTIALS_H
